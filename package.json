{
  "name": "hero-scroll-engine",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "frames:extract": "ffmpeg -i public/hero-video.mp4 -vf fps=24 /tmp/hero-frames/frame_%04d.png",
    "frames:convert": "for f in /tmp/hero-frames/*.png; do cwebp -q 75 \"$f\" -o \"public/hero-frames/$(basename ${f%.png}).webp\"; done",
    "frames:ffmpeg-webp": "ffmpeg -i public/hero-video.mp4 -vf fps=24 -c:v libwebp -quality 75 public/hero-frames/frame_%04d.webp"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5.4.0"
  }
}
